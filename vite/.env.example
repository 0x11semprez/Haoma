# Frontend environment variables for Haoma.
# Copy to `.env.local` and fill in only when the FastAPI backend lives
# outside the default Vite proxy target (vite.config.ts).
#
# Routing contract (read before setting these):
#   - Backend endpoints are `/health`, `/patients`, `/patients/{id}`, `/auth/badge`,
#     and WS `/ws/patients/{id}` — NO `/api` prefix on the server side.
#   - In dev, the Vite proxy rewrites `/api/*` → `/*` before reaching FastAPI
#     (REST only; the `/ws` proxy passes the path through untouched).
#   - In prod / off-origin, set VITE_API_URL to the bare backend origin
#     (do NOT include a trailing `/api` — requests already carry the path).

# Absolute base URL for REST calls. Optional — defaults to `/api` via the Vite dev proxy.
# VITE_API_URL=https://backend.haoma.example.com

# Absolute base URL for WebSocket. Optional — defaults to same origin via the Vite dev proxy.
# VITE_WS_URL=wss://backend.haoma.example.com
